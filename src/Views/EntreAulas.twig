{% extends '@app/Views/Layout.twig' %}

{% block title %}EntreAulas{% endblock %}

{% block content %}
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800">EntreAulas</h1>
  <p class="text-gray-500 mt-1">Sistema de gestión para aulas conectadas.</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

  {# Aulario #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-blue-600 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">Aulario</h2>
    <p class="text-sm text-gray-500">Gestión centralizada de recursos del aula.</p>
  </div>

  {# Alumnos #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-green-600 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">Alumnos</h2>
    <p class="text-sm text-gray-500">Gestión del alumnado y sus datos.</p>
  </div>

  {# SuperCafe / Comedor #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-orange-500 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">SuperCafe / Comedor</h2>
    <p class="text-sm text-gray-500">Pedidos del comedor con identificación QR.</p>
  </div>

  {# Panel Diario #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-purple-600 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">Panel Diario</h2>
    <p class="text-sm text-gray-500">¿Quién soy? Identificación fotográfica del alumnado.</p>
  </div>

  {# Proyectos #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-teal-600 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">Proyectos</h2>
    <p class="text-sm text-gray-500">Gestión de proyectos educativos.</p>
  </div>

</div>

<p class="mt-8 text-sm text-gray-400 text-center">
  Bienvenidx, <strong>{{ displayName }}</strong>. Selecciona un módulo para comenzar.
</p>
{% endblock %}
