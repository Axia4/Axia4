{% extends '@app/Views/Layout.twig' %}

{% block title %}La web del Club{% endblock %}

{% block content %}
<div class="mb-6">
  <div class="flex items-center gap-4">
    <img src="{{ config.url }}/static/logo-club.png" alt="Club" class="h-16 w-16" />
    <div>
      <h1 class="text-2xl font-bold text-gray-800">La web del Club</h1>
      <p class="text-gray-500 mt-1">Actividades, eventos y recursos del club.</p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

  {# Calendario #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-blue-600 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">Calendario</h2>
    <p class="text-sm text-gray-500">Próximas actividades y eventos del club.</p>
  </div>

  {# Fotos #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-pink-500 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">Fotos</h2>
    <p class="text-sm text-gray-500">Galería de imágenes de actividades.</p>
  </div>

  {% if isAuthenticated %}
  {# Editar datos (solo autenticados) #}
  <div class="bg-white rounded-2xl shadow-sm p-5">
    <div class="text-gray-500 mb-2">
      <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
    </div>
    <h2 class="font-semibold text-gray-800 mb-1">Editar datos</h2>
    <p class="text-sm text-gray-500">Actualiza la información del club.</p>
  </div>
  {% endif %}

</div>
{% endblock %}
