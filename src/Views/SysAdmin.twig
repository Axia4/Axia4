{% extends '@app/Views/Layout.twig' %}

{% block title %}SysAdmin{% endblock %}

{% block content %}
<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Panel de Administración</h1>
    <p class="text-gray-500 mt-1">Configuración y gestión de Axia4.</p>
  </div>
  <span class="text-xs bg-yellow-100 text-yellow-700 border border-yellow-300 rounded-full px-3 py-1">
    SysAdmin
  </span>
</div>

{# ── User management table ── #}
<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100">
    <h2 class="font-semibold text-gray-800">Usuarios ({{ users|length }})</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
        <tr>
          <th class="px-6 py-3 text-left">Usuario</th>
          <th class="px-6 py-3 text-left">Nombre</th>
          <th class="px-6 py-3 text-left">Email</th>
          <th class="px-6 py-3 text-left">Permisos</th>
          <th class="px-6 py-3 text-left">Auth</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {% for u in users %}
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-3 font-mono text-gray-700">{{ u.username }}</td>
          <td class="px-6 py-3 text-gray-700">{{ u.display_name ?? '—' }}</td>
          <td class="px-6 py-3 text-gray-500">{{ u.email ?? '—' }}</td>
          <td class="px-6 py-3">
            {% for perm in (u.permissions ?? []) %}
              <span class="inline-block bg-blue-50 text-blue-700 text-xs rounded px-2 py-0.5 mr-1">{{ perm }}</span>
            {% endfor %}
          </td>
          <td class="px-6 py-3 text-gray-500">
            {% if u.google_auth %}
              <span class="text-xs text-green-600">Google</span>
            {% else %}
              <span class="text-xs text-gray-400">Local</span>
            {% endif %}
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="5" class="px-6 py-8 text-center text-gray-400">
            No hay usuarios registrados.
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<p class="mt-4 text-xs text-gray-400 text-right">
  Sesión activa: {{ currentUser.display_name ?? currentUser.username ?? '—' }}
</p>
{% endblock %}
