{% extends '@app/Views/Layout.twig' %}

{% block title %}Mi Cuenta{% endblock %}

{% block content %}
<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl">

  {# Profile card #}
  <div class="bg-white rounded-2xl shadow-sm p-6 text-center">
    <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 text-2xl font-bold mx-auto mb-3">
      {{ (displayName|slice(0,1))|upper }}
    </div>
    <h2 class="text-xl font-bold text-gray-800 mb-2">¡Hola, {{ displayName }}!</h2>
    <div class="text-sm text-gray-600 space-y-1">
      <p><span class="font-medium">Email:</span> {{ email }}</p>
      <p><span class="font-medium">Usuario:</span> {{ username }}</p>
    </div>
    <a href="/?route=logout"
       class="mt-4 inline-block text-sm text-red-500 hover:underline">
      Cerrar sesión
    </a>
  </div>

  {# QR code card #}
  <div class="bg-white rounded-2xl shadow-sm p-6 text-center">
    <p class="font-semibold text-gray-700 mb-3">Código QR de acceso</p>
    <img
      src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={{ username|url_encode }}"
      alt="QR Code"
      class="mx-auto h-36 w-36"
    />
    <p class="text-xs text-gray-400 mt-3">
      Este código identifica tu nombre de usuario. No lo compartas en público.
    </p>
  </div>

</div>
{% endblock %}
